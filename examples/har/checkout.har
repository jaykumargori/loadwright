{
  "log": {
    "version": "1.2",
    "creator": {
      "name": "Loadwright example",
      "version": "1.0"
    },
    "entries": [
      {
        "request": {
          "method": "GET",
          "url": "https://httpbin.org/status/200",
          "headers": [
            {
              "name": "Accept",
              "value": "application/json"
            }
          ],
          "queryString": []
        }
      },
      {
        "request": {
          "method": "POST",
          "url": "https://httpbin.org/post",
          "headers": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "postData": {
            "mimeType": "application/json",
            "text": "{\"hello\":\"world\"}"
          }
        }
      }
    ]
  }
}
